def relatorio_financeiro_locacao(df: pd.DataFrame):
    print("\n--- VISÃO FINANCEIRA DE LOCAÇÕES ---")
    if 'status_pagamento' not in df.columns or 'valor_aluguel' not in df.columns:
        print("[!] Erro: Colunas de valor ou status não foram processadas corretamente.")
        return
    
    df_valido = df.dropna(subset=['valor_aluguel']).copy()
    df_valido = df_valido[df_valido['status_pagamento'] != 'N/A']
    
    total_apts = len(df_valido)
    total_alugueis = df_valido['valor_aluguel'].sum()
    
    for status in ['Em dia', 'Atrasado']:
        df_status = df_valido[df_valido['status_pagamento'] == status]
        qtd = len(df_status)
        soma = df_status['valor_aluguel'].sum()
        media = df_status['valor_aluguel'].mean() if qtd > 0 else 0
        porc_qtd = (qtd / total_apts) * 100 if total_apts > 0 else 0
        porc_valor = (soma / total_alugueis) * 100 if total_alugueis > 0 else 0
        
        print(f"\n** Pagamentos {status} **")
        print(f"Apartamentos: {qtd} ({porc_qtd:.2f}%)")
        print(f"Soma Arrecadada: {formatar_valor_moeda(soma)}")
        print(f"Média: {formatar_valor_moeda(media)} | Representação do Total: {porc_valor:.2f}%")

def ranking_clientes_vendas(df: pd.DataFrame):
    print("\n--- RANKING ESTATÍSTICO POR CLIENTE ---")
    if 'Cliente' not in df.columns or 'Valor da compra' not in df.columns:
        print("[!] Erro: Colunas essenciais ausentes.")
        return
        
    estatisticas = df.groupby('Cliente', as_index=False).agg(
        Qtd_Compras=('Valor da compra', 'count'),
        Gasto_Total=('Valor da compra', 'sum')
    )
    total_compras = estatisticas['Qtd_Compras'].sum()
    estatisticas['%'] = (estatisticas['Qtd_Compras'] / total_compras * 100).apply(lambda x: f"{x:.2f}%")
    estatisticas['Gasto_Total'] = estatisticas['Gasto_Total'].apply(formatar_valor_moeda)
    estatisticas = estatisticas.sort_values('Qtd_Compras', ascending=False)
    
    print(estatisticas.to_string(index=False))

def grafico_evolucao_vendas(df: pd.DataFrame):
    if 'Data de Venda' not in df.columns or 'Valor da compra' not in df.columns:
        print("[!] Colunas necessárias não encontradas para o gráfico.")
        return
    df_agrupado = df.groupby('Data de Venda')['Valor da compra'].sum().reset_index()
    plt.figure(figsize=(12, 6))
    sns.lineplot(data=df_agrupado, x='Data de Venda', y='Valor da compra', marker='o', color='b')
    plt.title("Evolução de Vendas ao Longo do Tempo")
    plt.gca().yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: formatar_valor_moeda(x)))
    plt.xticks(rotation=45)
    plt.tight_layout()
    plt.show()

