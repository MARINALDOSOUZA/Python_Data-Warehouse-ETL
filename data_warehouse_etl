def baixar_json_seguro(url: str) -> pd.DataFrame:
    logging.info(f"Conectando ao servidor para extração...")
    requisicao = urllib.request.Request(
        url,
        headers={'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0.0.0'}
    )
    with urllib.request.urlopen(requisicao) as resposta:
        dados_json = json.loads(resposta.read().decode('utf-8'))
    return extrair_dataframe_aninhado(dados_json)

def extrair_dataframe_aninhado(json_obj) -> pd.DataFrame:
    """Achata a estrutura JSON principal para um formato tabular com explosão em paralelo."""
    if isinstance(json_obj, list):
        df = pd.json_normalize(json_obj)
    elif isinstance(json_obj, dict):
        for chave, valor in json_obj.items():
            if isinstance(valor, list) and len(valor) > 0 and isinstance(valor[0], dict):
                df = pd.json_normalize(valor)
                break
        else:
            df = pd.json_normalize(json_obj)
    else:
        raise ValueError("Estrutura JSON não suportada.")

    # PULO DO GATO: Explodir todas as colunas simultaneamente!
    # Isso alinha os dados e impede o ArrayMemoryError (explosão cartesiana).
    colunas_explodir = [col for col in df.columns if df[col].apply(lambda x: isinstance(x, list)).any()]
    if colunas_explodir:
        df = df.explode(colunas_explodir, ignore_index=True)
        
    return df

def gerenciar_backup_e_io(caminho_arquivo: Path, limite=2):
    if not caminho_arquivo.exists(): return
    PASTA_BACKUP.mkdir(parents=True, exist_ok=True)
    carimbo_tempo = datetime.now().strftime("%Y%m%d_%H%M%S")
    nome_backup = PASTA_BACKUP / f"{caminho_arquivo.stem}_{carimbo_tempo}{caminho_arquivo.suffix}"
    shutil.copy2(caminho_arquivo, nome_backup)
    logging.info(f"Backup seguro gerado: {nome_backup.name}")
    
    arquivos_backup = sorted(PASTA_BACKUP.glob(f"{caminho_arquivo.stem}_*{caminho_arquivo.suffix}"))
    if len(arquivos_backup) > limite:
        for arq in arquivos_backup[:-limite]:
            arq.unlink(missing_ok=True)

