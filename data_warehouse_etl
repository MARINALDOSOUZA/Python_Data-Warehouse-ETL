def processar_fluxo(tipo: str) -> pd.DataFrame:
    url = FONTES_DADOS[tipo]
    extensao = ".parquet" if tipo == 'hospedagem' else ".csv"
    caminho_local = DIRETORIO_TRABALHO / f"df_processado_{tipo}{extensao}"
    
    if caminho_local.exists():
        if input(f"Arquivo local de {tipo.upper()} detectado. Deseja forçar atualização online? (s/n): ").strip().lower() != 's':
            df = pd.read_parquet(caminho_local) if extensao == '.parquet' else pd.read_csv(caminho_local)
            print(f"\n[OK] Arquivo carregado do disco ({len(df)} linhas).")
            return df
        gerenciar_backup_e_io(caminho_local)

    df_bruto = baixar_json_seguro(url)
    
    if tipo == 'hospedagem': df_final = tratar_hospedagem(df_bruto)
    elif tipo == 'locacao': df_final = tratar_locacao(df_bruto)
    elif tipo == 'vendas': df_final = tratar_vendas(df_bruto)

    if extensao == '.parquet': df_final.to_parquet(caminho_local, index=False)
    else: df_final.to_csv(caminho_local, index=False)
    
    print(f"\n[OK] Dados extraídos e otimizados com sucesso!")
    return df_final

