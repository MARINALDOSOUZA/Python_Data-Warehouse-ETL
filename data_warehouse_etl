def formatar_valor_moeda(valor) -> str:
    if pd.isna(valor): return "N/A"
    return f"R$ {float(valor):,.2f}".replace(",", "X").replace(".", ",").replace("X", ".")

def extrair_valor_numerico_seguro(valor) -> float:
    # Agora que explodimos corretamente, podemos simplificar e garantir a limpeza
    if pd.isna(valor): 
        return np.nan
        
    texto = str(valor)
    for c in ["['", "']", '["', '"]', '[', ']']: 
        texto = texto.replace(c, "")
        
    texto_limpo = re.sub(r'[^\d.,]', '', texto)
    if not texto_limpo: 
        return np.nan
        
    if ',' in texto_limpo: 
        texto_limpo = texto_limpo.replace('.', '').replace(',', '.')
        
    try:
        return float(texto_limpo)
    except ValueError:
        return np.nan

def texto_extenso_para_numero(texto):
    mapa = {
        'zero': 0, 'um': 1, 'uma': 1, 'dois': 2, 'duas': 2, 'tres': 3, 'três': 3, 'quatro': 4,
        'cinco': 5, 'seis': 6, 'sete': 7, 'oito': 8, 'nove': 9, 'dez': 10, 'onze': 11, 'doze': 12,
        'vinte': 20, 'trinta': 30, 'cem': 100, 'cento': 100, 'duzentos': 200, 'mil': 1000
    }
    palavras = re.sub(r'[^a-záéíóúãõç\s]', '', str(texto).lower()).split()
    total = 0; atual = 0
    for palavra in palavras:
        if palavra in mapa:
            if mapa[palavra] == 1000:
                if atual == 0: atual = 1
                total += atual * 1000
                atual = 0
            else:
                atual += mapa[palavra]
    return total + atual if total + atual > 0 else None

def otimizar_memoria(df: pd.DataFrame) -> pd.DataFrame:
    df_otimizado = df.copy()
    for col in df_otimizado.select_dtypes(include=['float64']).columns:
        df_otimizado[col] = pd.to_numeric(df_otimizado[col], downcast='float')
    for col in df_otimizado.select_dtypes(include=['int64']).columns:
        df_otimizado[col] = pd.to_numeric(df_otimizado[col].fillna(0), downcast='integer')
    return df_otimizado

