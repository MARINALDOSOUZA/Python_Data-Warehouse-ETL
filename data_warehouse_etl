# =====================================================================
def tratar_hospedagem(df: pd.DataFrame) -> pd.DataFrame:
    df_tratado = df.copy()
    float_cols = ['avaliacao_geral', 'taxa_deposito', 'taxa_limpeza', 'preco']
    string_cols = ['experiencia_local', 'descricao_local', 'descricao_vizinhanca', 'modelo_cama', 'comodidades']

    for coluna in df_tratado.columns:
        if coluna in float_cols:
            df_tratado[coluna] = df_tratado[coluna].apply(extrair_valor_numerico_seguro)
        elif coluna in string_cols and df_tratado[coluna].dtype == 'object':
            df_tratado[coluna] = df_tratado[coluna].apply(lambda x: ', '.join(map(str, x)) if isinstance(x, list) else str(x))
            df_tratado[coluna] = df_tratado[coluna].str.lower().str.replace(r'[^\w\s\',\-\,\.]', '', regex=True).str.strip().astype('string')
    
    df_tratado.columns = [col.strip().lower().replace(" ", "_") for col in df_tratado.columns]
    return otimizar_memoria(df_tratado)

def tratar_locacao(df: pd.DataFrame) -> pd.DataFrame:
    df_tratado = df.copy()
    col_pag = next((c for c in df_tratado.columns if re.search(r'datas_de_pagamento', c, re.I)), None)
    col_venc = next((c for c in df_tratado.columns if re.search(r'datas_combinadas', c, re.I)), None)

    for col in df_tratado.columns:
        if re.search(r'data|date|dt', col, re.I):
            df_tratado[col] = pd.to_datetime(df_tratado[col], errors='coerce', dayfirst=True)
        elif col == 'valor_aluguel':
            valores = []
            for val in df_tratado[col].astype(str):
                num = extrair_valor_numerico_seguro(val)
                if pd.isna(num): num = texto_extenso_para_numero(val)
                valores.append(num)
            df_tratado[col] = valores
        elif df_tratado[col].dtype == 'object':
            df_tratado[col] = df_tratado[col].astype(str).str.replace(r'[()]', '', regex=True).str.strip().str.title()
            
    if col_pag and col_venc:
        df_tratado['status_pagamento'] = 'N/A'
        mascara_validas = df_tratado[col_pag].notna() & df_tratado[col_venc].notna()
        df_tratado.loc[mascara_validas, 'status_pagamento'] = np.where(
            df_tratado.loc[mascara_validas, col_pag] <= df_tratado.loc[mascara_validas, col_venc],
            'Em dia', 'Atrasado'
        )
    return otimizar_memoria(df_tratado)

def tratar_vendas(df: pd.DataFrame) -> pd.DataFrame:
    df_tratado = df.copy()
    for col in df_tratado.columns:
        if re.search(r'data|date|dt|venda', col, re.I) and 'Data de Venda' not in df_tratado.columns:
            df_tratado[col] = pd.to_datetime(df_tratado[col], errors='coerce', dayfirst=True)
            df_tratado.rename(columns={col: 'Data de Venda'}, inplace=True)
        elif re.search(r'valor', col, re.I):
            df_tratado[col] = df_tratado[col].apply(extrair_valor_numerico_seguro)
        elif col == 'Cliente':
            df_tratado[col] = df_tratado[col].astype(str).str.normalize('NFKD').str.encode('ascii', errors='ignore').str.decode('utf-8')
            df_tratado[col] = df_tratado[col].str.replace(r'[^a-zA-Z\s]', '', regex=True).str.title().str.strip()
    return otimizar_memoria(df_tratado)

